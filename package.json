{
  "name": "calorie-counter",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "format": "bunx prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun run typecheck:app && bun run typecheck:convex",
    "typecheck:app": "tsc --noEmit",
    "typecheck:convex": "tsc --noEmit -p convex/tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
